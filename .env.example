# PitchPal environment configuration
#
# Copy this file to `.env` and fill in your key to enable live Gemini responses:
#   cp .env.example .env
#
# The app runs WITHOUT a key in deterministic "mock" mode, so judges can try it
# out of the box. Add a key only when you want live, generative answers.

# Google Gemini API key. Get one at https://aistudio.google.com/apikey
# Leave empty to run in mock mode.
GEMINI_API_KEY=

# Model to use for live responses (optional). Defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Production server port (optional). Defaults to 8080.
PORT=8080
