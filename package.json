{
  "name": "pitchpal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PitchPal — a multilingual, accessible GenAI stadium companion for FIFA World Cup 2026 fans.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
